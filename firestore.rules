rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function validTemplateId(id) {
      return id == 'kawaii-letter'
        || id == '100-reasons'
        || id == 'our-gallery'
        || id == 'dark-romance'
        || id == 'our-story'
        || id == 'midnight-love'
        || id == 'rose-whisper'
        || id == 'golden-promise'
        || id == 'iva-birthday'
        || id == 'birthday-candles'
        || id == 'date-invite'
        || id == 'sky-love'
        || id == 'chat-reveal';
    }

    function isOwnerPending() {
      return isSignedIn()
        && resource.data.status == 'pending'
        && resource.data.ownerUid == request.auth.uid;
    }

    function isOwnerTestPublish() {
      return isOwnerPending()
        && request.resource.data.status == 'active'
        && request.resource.data.stripeSessionId.matches('test-skip-.*')
        && request.resource.data.checkoutOwnerUid == request.auth.uid
        && request.resource.data.publishedAt is timestamp
        && request.resource.data.checkoutStartedAt is timestamp
        && request.resource.data.expiresAt == null
        && !request.resource.data.keys().hasAny(['ownerEmail', 'checkoutOwnerEmail'])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'stripeSessionId',
          'expiresAt',
          'checkoutOwnerUid',
          'checkoutStartedAt',
          'publishedAt',
          'ownerEmail',
          'checkoutOwnerEmail'
        ]);
    }

    match /pages/{pageId} {
      // Anyone can read active pages (recipient view).
      // Pending drafts are private to their owner.
      allow read: if resource.data.status == 'active' || isOwnerPending();

      // Signed-in users can create only their own pending draft records.
      allow create: if isSignedIn()
                    && request.resource.data.status == 'pending'
                    && request.resource.data.id == pageId
                    && validTemplateId(request.resource.data.templateId)
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.keys().hasOnly([
                      'id',
                      'status',
                      'templateId',
                      'templateVersion',
                      'recipientName',
                      'senderName',
                      'showSenderName',
                      'showFooter',
                      'palette',
                      'font',
                      'scenes',
                      'reasons',
                      'musicEnabled',
                      'musicUrl',
                      'stripeSessionId',
                      'ownerUid',
                      'createdAt',
                      'expiresAt'
                    ]);

      // Owners can edit only mutable draft fields while status is pending.
      allow update: if (
                      isOwnerPending()
                      && validTemplateId(request.resource.data.templateId)
                      && request.resource.data.status == 'pending'
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                        'templateVersion',
                        'recipientName',
                        'senderName',
                        'showSenderName',
                        'showFooter',
                        'palette',
                        'font',
                        'scenes',
                        'reasons',
                        'musicEnabled',
                        'musicUrl',
                        'stripeSessionId',
                        'checkoutOwnerUid',
                        'checkoutStartedAt'
                      ])
                    ) || isOwnerTestPublish();

      // Active publish is server-driven. Test-mode fallback can activate owner drafts
      // only with tightly scoped fields via isOwnerTestPublish().
    }
  }
}
